{
	"include": ["src", "worker-configuration.d.ts"],
	"exclude": ["node_modules", "dist"],
	"compilerOptions": {
		"strict": true,
		"skipLibCheck": true,
		"lib": ["dom", "es2022"],
		"module": "NodeNext",
